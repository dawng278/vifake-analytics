{
  "manifest_version": 3,
  "name": "ViFake - Bảo vệ trẻ em khỏi lừa đảo",
  "version": "1.0.0",
  "description": "Phát hiện nội dung lừa đảo nhắm vào trẻ em Việt Nam trên Facebook, YouTube, TikTok. 1-click kiểm tra, kết quả tức thì.",
  "permissions": [
    "storage",
    "activeTab",
    "contextMenus",
    "scripting"
  ],
  "host_permissions": [
    "https://*.facebook.com/*",
    "https://*.youtube.com/*",
    "https://*.tiktok.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.facebook.com/*",
        "https://www.youtube.com/*",
        "https://*.tiktok.com/*"
      ],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["https://*.facebook.com/*", "https://www.youtube.com/*", "https://*.tiktok.com/*"]
    }
  ]
}
